{
    "rule1": {
        "id": 1,
        "enabled": false,
        "action": "alert",
        "message": "Probe Flooding",
        "class": "arp",
        "severity": 2,
        "scope": {
            "interfaces": [
                "eth0",
                "wlan0"
            ]
        },
        "match": {
            "ip": {
                "src_ip": "any",
                "dst_ip": "any",
                "ip_version": [
                    4,
                    6
                ]
            },
            "transport": {
                "protocol": [
                    "arp"
                ],
                "src_port": "any",
                "dst_port": "any"
            },
            "direction": "any"
        },
        "context": {
            "flow": {
                "state": "any"
            },
            "limits": {
                "max_conn_rate": {
                    "per": "src_ip",
                    "connections": 15,
                    "interval": 1.0
                }
            }
        },
        "behaviour": {
            "per_src": {
                "max_requests_per_second": 600
            }
        }
    },
    "rule2": {
        "id": 2,
        "enabled": false,
        "action": "alert",
        "message": "Authentication Brute-Force",
        "class": "eapol",
        "severity": 1,
        "scope": {
            "interfaces": [
                "eth0",
                "wlan0"
            ]
        },
        "match": {
            "ip": {
                "src_ip": "any",
                "dst_ip": "self",
                "ip_version": [
                    4,
                    6
                ]
            },
            "transport": {
                "protocol": [
                    "http",
                    "https",
                    "ssh",
                    "rdp",
                    "smb",
                    "ftp"
                ],
                "src_port": "any",
                "dst_port": "any"
            },
            "direction": "ingress"
        },
        "context": {
            "flow": {
                "state": "established"
            },
            "limits": {
                "max_conn_rate": {
                    "per": "src_ip",
                    "connections": 15,
                    "interval": 1.0
                }
            }
        },
        "behaviour": {
            "per_src": {
                "max_requests_per_second": 15
            }
        }
    },
    "rule3": {
        "id": 3,
        "enabled": true,
        "action": "alert",
        "message": "TCP Port Scan",
        "class": "tcp",
        "severity": 2,
        "scope": {
            "interfaces": [
                "any"
            ]
        },
        "match": {
            "ip": {
                "src_ip": "any",
                "dst_ip": "any",
                "ip_version": [
                    4,
                    6
                ]
            },
            "transport": {
                "protocol": [
                    "tcp"
                ],
                "src_port": "any",
                "dst_port": "any"
            },
            "direction": "ingress"
        },
        "context": {
            "flow": {
                "state": "new"
            },
            "limits": {
                "max_conn_rate": {
                    "per": "src_ip",
                    "connections": 4,
                    "interval": 3.0
                }
            }
        },
        "behaviour": {
            "per_src": {
                "max_requests_per_second": 600
            }
        }
    },
    "rule4": {
        "id": 4,
        "enabled": false,
        "action": "alert",
        "message": "UDP Port Scan",
        "class": "udp",
        "severity": 2,
        "scope": {
            "interfaces": [
                "eth0",
                "wlan0"
            ]
        },
        "match": {
            "ip": {
                "src_ip": "any",
                "dst_ip": "any",
                "ip_version": [
                    4,
                    6
                ]
            },
            "transport": {
                "protocol": [
                    "tcp"
                ],
                "src_port": "any",
                "dst_port": "any"
            },
            "direction": "any"
        },
        "context": {
            "flow": {
                "state": "any"
            },
            "limits": {
                "max_conn_rate": {
                    "per": "src_ip",
                    "connections": 15,
                    "interval": 1.0
                }
            }
        },
        "behaviour": {
            "per_src": {
                "max_requests_per_second": 600
            }
        }
    }
}