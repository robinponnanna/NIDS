{
    "rule1": {
        "id": 1,
        "enabled": true,
        "action": "alert",
        "message": "Probe Flooding",
        "class": "arp",
        "severity": 2,
        "scope": {
            "interfaces": [
                "eth0",
                "wlan0"
            ]
        },
        "match": {
            "ip": {
                "src_ip": "any",
                "dst_ip": "any",
                "ip_version": [
                    4,
                    6
                ]
            },
            "transport": {
                "protocol": [
                    "arp"
                ],
                "src_port": "any",
                "dst_port": "any"
            },
            "direction": "ingress"
        },
        "context": {
            "flow": {
                "state": "any"
            },
            "limits": {
                "max_conn_rate": {
                    "per": "src_ip",
                    "connections": 15,
                    "interval_ms": 1000
                }
            }
        },
        "behaviour": {
            "per_src": {
                "max_requests_per_minute": 600
            },
            "per_service": {
                "service_id": "ota_update",
                "max_cmd_per_hour": 100
            }
        },
        "metadata": {
            "tags": [
                "arp"
            ],
            "created-on": "18-07-2026"
        }
    },
